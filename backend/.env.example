BOT_TOKEN=123456:ABC-your-bot-token
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                # для Whisper (голос). Можна лишити пустим — буде тільки текст
WEBAPP_URL=https://pult.vercel.app   # URL Mini App (HTTPS), для кнопки в боті
DATABASE_URL=sqlite+aiosqlite:///./pult.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

OWNER_TELEGRAM_ID=111111111          # telegram_id власника
ALLOWED_USER_IDS=[111111111,222222222]

CLAUDE_MODEL=claude-opus-4-8
MONTHLY_BUDGET=17000                 # бюджет місяця в грн, для відсотка на панелі
CORS_ORIGINS=["http://localhost:5173"]
